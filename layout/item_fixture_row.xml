<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/layout_fixture_status_badge"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_row_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Segotlo U15 vs Madikwe Stars"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_row_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="15 Jun 2026 • 10:00 • Stadium"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_fixture_status_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_row_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 - 1"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="18sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_row_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="#11000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="UPCOMING"
            android:textColor="@color/academy_yellow"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>