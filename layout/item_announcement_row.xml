<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/academy_yellow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_ann_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Announcement Title"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_ann_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="This is the description of the announcement."
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ann_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="27 May 2026"
            android:textColor="#AAAAAA"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>